# === Content Intelligence Engine (CIE) v2.0 ===

# ── 프로젝트 정보 ──
CIE_PROJECT_NAME="BIOJUHO AI Lab"
CIE_PROJECT_MESSAGE="AI 기술로 세상을 더 나은 곳으로"
CIE_TARGET_AUDIENCE="개발자, AI 연구자, 기술 트렌드에 관심 있는 MZ세대"
CIE_PROJECT_FIELDS="AI,LLM,자동화,DeSci"

# ── 플랫폼 설정 ──
CIE_PLATFORMS=x,threads,naver
CIE_TREND_TOP_N=5

# ── 네이버 API (https://developers.naver.com/apps) ──
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── Notion Content Hub ──
CIE_NOTION_DATABASE_ID=
CIE_NOTION_PUBLISH=false

# ── X(Twitter) 자동 발행 ──
CIE_X_PUBLISH=false
CIE_X_MIN_QA_SCORE=75
X_ACCESS_TOKEN=
# X_ACCESS_TOKEN should be an OAuth 2.0 user-context token obtained via
# Authorization Code with PKCE, not an app-only bearer token.

# ── QA 설정 ──
CIE_QA_ENABLED=true
CIE_QA_MIN_SCORE=70
CIE_QA_MAX_RETRIES=1

# ── LLM 티어 (LIGHTWEIGHT / MEDIUM / HEAVY) ──
CIE_TIER_TREND=LIGHTWEIGHT
CIE_TIER_REGULATION=MEDIUM
CIE_TIER_CONTENT=HEAVY
CIE_TIER_QA=LIGHTWEIGHT

# ── GetDayTrends DB 연동 (비워두면 자동 탐지) ──
CIE_GDT_DB_PATH=

# ── 스케줄 ──
CIE_SCHEDULE=weekly

# ── 규제 점검 기간 (일) ──
CIE_REGULATION_LOOKBACK=30
