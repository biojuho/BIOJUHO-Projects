# =====================================================
#  getdaytrends v4.1 — 환경변수 예시 (복사하여 .env로 사용)
#  LLM API 키는 상위 루트의 shared.llm 모듈에서 관리
# =====================================================

# ── 저장 방식 ─────────────────────────────────────────
# "notion" | "google_sheets" | "both" | "none"
STORAGE_TYPE=notion

# ── Notion (STORAGE_TYPE=notion 일 때 필수) ──────────
# https://www.notion.so/my-integrations 에서 발급
NOTION_TOKEN=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here
ENABLE_CONTENT_HUB=false
CONTENT_HUB_DATABASE_ID=

# ── Google Sheets (STORAGE_TYPE=google_sheets 일 때) ─
GOOGLE_SERVICE_ACCOUNT_JSON=credentials.json
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ── 생성 페르소나 ────────────────────────────────────
# "biojuho" | "report" | "classic"
TONE=joongyeon
# 장문/Threads/블로그용 프로필: report | classic
EDITORIAL_PROFILE=report

# ── 스케줄 & 수집 ────────────────────────────────────
SCHEDULE_INTERVAL_MINUTES=360   # 파이프라인 실행 간격 (분)
DEFAULT_LIMIT=10                # 처리할 트렌드 수
DEFAULT_COUNTRY=korea           # 기본 국가 (korea/us/japan 등)
DEDUPE_WINDOW_HOURS=6           # 동일 트렌드 중복 제거 윈도우 (시간)
ENABLE_PARALLEL_COUNTRIES=true
COUNTRY_PARALLEL_LIMIT=3

# ── 바이럴 스코어링 필터 ─────────────────────────────
MIN_VIRAL_SCORE=60             # 미만이면 콘텐츠 생성 건너뜀
ALERT_THRESHOLD=75             # 이상이면 Telegram/Discord/Slack/Email 알림 전송
EXCLUDE_CATEGORIES=정치,연예    # 이 카테고리 트렌드 자동 제외 (쉼표 구분)

# ── 콘텐츠 생성 기준 점수 ─────────────────────────────
LONG_FORM_MIN_SCORE=95          # 이상만 Premium+ 장문 생성 (비용↑)
THREAD_MIN_SCORE=999            # 기본 비활성
THREADS_MIN_SCORE=999           # 기본 비활성
BLOG_MIN_SCORE=999              # 기본 비활성

# ── v4.1 트렌드 검증 & 하이브리드 스코어링 ─────────────
# Phase 1: 멀티소스 교차 검증 (0~4점)
# 0=볼륨없음, 1=볼륨, 2=볼륨+X, 3=볼륨+X+뉴스, 4=볼륨+X+뉴스+Reddit
MIN_CROSS_SOURCE_CONFIDENCE=2   # 미만이면 viral_potential ×0.65 패널티

# Phase 2: 하이브리드 스코어링 가중치
VIRAL_SCORE_LLM_WEIGHT=0.6     # LLM 점수 비중 (0.0~1.0)

# Phase 3: 히스토리 패턴 보정
ENABLE_HISTORY_CORRECTION=true

# Phase 4: 중연 킥 포인트
# joongyeon_kick >= 이 값이면 LONG_FORM_MIN_SCORE 조건을 완화
JOONGYEON_KICK_LONG_FORM_THRESHOLD=75

# ── 기능 플래그 ───────────────────────────────────────
ENABLE_CLUSTERING=true           # 유사 트렌드 클러스터링
ENABLE_CANVA_VISUALS=false
ENABLE_LONG_FORM=false           # 장문 기본 비활성
ENABLE_THREADS=false             # X 멀티 쓰레드 기본 비활성
SMART_SCHEDULE=true              # 최적 포스팅 타이밍 자동 조절
NIGHT_MODE=true                  # 야간(02~07시) 실행 빈도 축소
ENABLE_SENTIMENT_FILTER=true      # 유해 트렌드 자동 필터 (safety_flag)
ENABLE_AB_VARIANTS=false         # A/B 변형 생성
ENABLE_MULTILANG=false           # 멀티언어 생성
ENABLE_QUALITY_FEEDBACK=true     # QA 피드백 루프
ENABLE_CONTENT_DIVERSITY=true    # 프롬프트 다양성 주입
ENABLE_TAP=true                  # TAP 스냅샷 + 알림 큐
ENABLE_EMBEDDING_CLUSTERING=true
EMBEDDING_CLUSTER_THRESHOLD=0.75
ENABLE_ADAPTIVE_VOICE=true
ENABLE_TIERED_COLLECTION=true
ENABLE_LLM_CLUSTERING=false
ENABLE_SOURCE_QUALITY_TRACKING=true
ENABLE_HISTORY_CORRECTION=true

# ── 성능 & DB ────────────────────────────────────────
MAX_WORKERS=10                  # 동시 HTTP 요청 수
CACHE_VOLUME_BUCKET=5000         # 핑거프린트 볼륨 버킷 크기
DATA_RETENTION_DAYS=90          # DB 보존 기간(일)
NOTION_SEM_LIMIT=10             # Notion 동시 저장 세마포어
DB_PATH=data/getdaytrends.db     # SQLite DB 경로

# ── 일일 예산 제어 ────────────────────────────────────
DAILY_BUDGET_USD=3.0            # 일 예산 상한 ($)
PEAK_BUDGET_MULTIPLIER=0.5      # 야간(22~07시) 예산 배율
COST_ALERT_PCT=70.0             # 예산의 이 % 도달 시 경고 알림

# ── 알림 채널 (선택) ──────────────────────────────────
# @BotFather에서 봇 생성 후 토큰 발급
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Discord 서버 설정 > 연동 > 웹훅에서 URL 생성
DISCORD_WEBHOOK_URL=
# Slack Incoming Webhook URL
SLACK_WEBHOOK_URL=
# SMTP 알림 (TLS:587, SSL:465)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL=
ALERT_THRESHOLD=70

# ── X API (선택) ─────────────────────────────────────
# 없으면 Twikit 또는 대체 수집 경로로 폴백
# https://developer.x.com 에서 발급
TWITTER_BEARER_TOKEN=
X_ACCESS_TOKEN=
X_CLIENT_ID=
X_CLIENT_SECRET=

# ── Twikit (선택, X API 없을 때 자동 폴백) ──────────
# 전용 X 계정 사용 권장
TWIKIT_USERNAME=
TWIKIT_EMAIL=
TWIKIT_PASSWORD=
TWIKIT_COOKIE_SECRET=

# ── LLM API 키 (공유 루트 권장) ─────────────────────
# shared.llm 모듈이 아래 키 순서로 자동 폴백:
# deepseek → gemini → grok → openai → anthropic → moonshot → zhipu
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
XAI_API_KEY=your_xai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
MOONSHOT_API_KEY=your_moonshot_api_key_here
ZHIPUAI_API_KEY=your_zhipuai_api_key_here

# ── Canva 이미지 생성(옵션) ──────────────────────────
CANVA_API_KEY=
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_TEMPLATE_ID=

# ── 기타 서비스 ───────────────────────────────────────
IMGBB_API_KEY=your_imgbb_api_key_here

# ── PostgreSQL (선택 — 기본값: SQLite) ───────────────
# DATABASE_URL=postgresql://user:pw@host:5432/getdaytrends
ALLOW_SQLITE_FALLBACK=true
# 비용 추적 DB는 기본적으로 프로젝트 로컬 SQLite를 사용합니다. 필요하면 별도 URL로 재정의하세요.
# LLM_COSTS_DATABASE_URL=sqlite:///data/llm_costs.db

# ═══════════════════════════════════════════════════
#  v9.0 Phase A: 비용 최적화
# ═══════════════════════════════════════════════════
ENABLE_LLM_CLUSTERING=false
JACCARD_CLUSTER_THRESHOLD=0.35

QA_SKIP_CACHED=true
QA_SKIP_HIGH_SCORE=85
QA_SKIP_CATEGORIES=날씨,음식,스포츠
QUALITY_FEEDBACK_MIN_SCORE=50
THREADS_QUALITY_MIN_SCORE=65
LONG_FORM_QUALITY_MIN_SCORE=70
BLOG_QUALITY_MIN_SCORE=75
GENERATION_MODE=

# ═══════════════════════════════════════════════════
#  v9.0 Phase B: 품질 최적화
# ═══════════════════════════════════════════════════
# Watchlist: 등장 시 즉시 알림 받을 키워드 (쉼표 구분)
WATCHLIST_KEYWORDS=

# 벨로시티 지표: 런 간 볼륨 상승 속도를 신호 점수에 반영
ENABLE_VELOCITY_SCORING=true

# ── TAP (Trend Arbitrage Publisher) ───────────────────
TAP_LOOKBACK_HOURS=12
TAP_MIN_VIRAL_SCORE=60
TAP_SNAPSHOT_MAX_AGE_MINUTES=30
TAP_BOARD_LIMIT=10
TAP_TEASER_COUNT=3
TAP_ALERT_TOP_K=3
TAP_ALERT_MIN_PRIORITY=80.0
TAP_ALERT_MIN_VIRAL_SCORE=75
TAP_ALERT_COOLDOWN_MINUTES=180
ENABLE_TAP_ALERT_QUEUE=true
ENABLE_TAP_ALERT_DISPATCH=false
TAP_ALERT_DISPATCH_BATCH_SIZE=5

# ── 콘텐츠 허브/옵션 ─────────────────────────────────
ENABLE_STREAMING_PIPELINE=false
STREAMING_GENERATOR_CONCURRENCY=3
STREAMING_STAGE_TIMEOUT=120

# ── 고급 기능 토글/임계치 ────────────────────────────
TARGET_LANGUAGES=ko
REQUIRED_SOURCE_COMBINATIONS=twitter+news,reddit+news,twitter+reddit
HARD_DROP_TOPIC_KEYWORDS=fursuit,cosplay,lol,league of legends,viego,patch notes,buff,nerf
MAX_CONTENT_AGE_HOURS=24
FRESHNESS_PENALTY_STALE=0.85
FRESHNESS_PENALTY_EXPIRED=0.7
ENABLE_ZERO_CONTENT_PREVENTION=true
NICHE_BONUS_POINTS=10
