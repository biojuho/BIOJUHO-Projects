{
  "typeCheckingMode": "basic",
  "pythonVersion": "3.12",
  "pythonPlatform": "All",
  "include": [
    "packages/shared",
    "automation/getdaytrends",
    "automation/content-intelligence",
    "apps/dashboard"
  ],
  "exclude": [
    "**/node_modules",
    "**/.venv",
    "**/venv",
    "**/archive",
    "**/var",
    "**/.smoke-tmp",
    "**/dist",
    "**/build"
  ],
  "reportMissingImports": "warning",
  "reportMissingTypeStubs": false,
  "reportUnnecessaryTypeIgnoreComment": false,
  "reportUnusedImport": "warning",
  "executionEnvironments": [
    {
      "root": "packages/shared",
      "extraPaths": [
        "packages"
      ]
    },
    {
      "root": "automation/getdaytrends",
      "extraPaths": [
        "packages",
        "automation/getdaytrends"
      ]
    },
    {
      "root": "automation/content-intelligence",
      "extraPaths": [
        "packages",
        "automation/content-intelligence"
      ]
    },
    {
      "root": "apps/dashboard",
      "extraPaths": [
        "packages",
        "automation",
        "automation/getdaytrends",
        "automation/DailyNews",
        "apps/desci-platform"
      ]
    }
  ]
}
