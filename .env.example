# AI Projects Workspace - Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to Git!

# ============================================
# PostgreSQL Configuration (Supabase / Local)
# ============================================
DATABASE_URL=postgresql://postgres:your_secure_password_here@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=ai_projects
POSTGRES_PORT=5433
MQTT_PORT=1884
MQTT_WS_PORT=9001
AGRIGUARD_PORT=8003

# ============================================
# LLM API Keys
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
XAI_API_KEY=your_grok_api_key_here
MOONSHOT_API_KEY=your_moonshot_api_key_here
XIAOMI_MIMO_API_KEY=your_mimo_api_key_here

# ============================================
# Firebase Configuration
# ============================================
# Frontend (Vite)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123def456

# Backend (Python)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/firebase-service-account.json

# ============================================
# Blockchain / Web3
# ============================================
WEB3_PROVIDER_URI=https://sepolia.infura.io/v3/your_infura_key
PRIVATE_KEY=0x_your_wallet_private_key_here  # NEVER commit this!
AGRIGUARD_PRIVATE_KEY=0x_your_agriguard_key_here

# ============================================
# IPFS (Pinata)
# ============================================
PINATA_API_KEY=your_pinata_api_key
PINATA_API_SECRET=your_pinata_api_secret

# ============================================
# External Services
# ============================================
FIRECRAWL_API_KEY=your_firecrawl_key
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
LINEAR_API_KEY=your_linear_api_key
SENTRY_DSN=your_sentry_dsn
NOTION_API_KEY=your_notion_key

# ============================================
# API URLs
# ============================================
VITE_API_URL=http://localhost:8000
ENV=development

# ============================================
# Feature Flags
# ============================================
# ALLOW_TEST_BYPASS=true  # DEV ONLY - DO NOT USE IN PRODUCTION
ENABLE_DEEPSEEK_KO_LONGFORM=false

# ============================================
# Pydantic AI
# ============================================
PYDANTIC_AI_MODEL=google-gla:gemini-2.5-flash-lite
