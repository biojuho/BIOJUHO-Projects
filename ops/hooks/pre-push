#!/bin/sh
# pre-push hook - run minimal smoke tests before push.
# Install: python ops/hooks/install_hooks.py

if ! python ops/hooks/install_hooks.py --check 2>/dev/null; then
    echo "Git hook install check failed. Push blocked."
    echo "   Run 'python ops/hooks/install_hooks.py' to refresh the installed hook."
    exit 1
fi

echo "==> Running smoke tests before push..."
if ! python -m pytest \
    tests/test_workspace_smoke.py \
    tests/test_pre_push_hook.py \
    tests/test_autoresearch_objective_coverage.py \
    tests/test_autoresearch_completion_audit.py \
    tests/test_dashboard_api.py \
    tests/test_mcp_service_runtime_smoke.py \
    tests/test_mcp_otel_collector_handoff.py \
    tests/test_external_credential_boundary_audit.py \
    tests/test_external_credential_handoff.py \
    tests/test_external_credential_live_verify.py \
    tests/test_telegram_notification_live_verify.py \
    tests/test_agent_workflow_gate_runner.py \
    tests/test_github_modernization_radar.py \
    tests/test_github_source_freshness.py \
    tests/test_github_source_review_queue.py \
    tests/test_github_source_commit_digest.py \
    tests/test_canva_widget_click_smoke.py \
    tests/test_dev_server_browser_smoke.py \
    tests/test_dev_server_mcp_contract.py \
    tests/test_dev_server_mcp_runtime.py \
    tests/test_dev_server_mcp_runtime_smoke.py \
    -q --tb=line 2>/dev/null; then
    echo "Smoke test failed. Push blocked."
    echo "   Run 'python -m pytest tests/test_workspace_smoke.py tests/test_pre_push_hook.py tests/test_autoresearch_objective_coverage.py tests/test_autoresearch_completion_audit.py tests/test_dashboard_api.py tests/test_mcp_service_runtime_smoke.py tests/test_mcp_otel_collector_handoff.py tests/test_external_credential_boundary_audit.py tests/test_external_credential_handoff.py tests/test_external_credential_live_verify.py tests/test_telegram_notification_live_verify.py tests/test_agent_workflow_gate_runner.py tests/test_github_modernization_radar.py tests/test_github_source_freshness.py tests/test_github_source_review_queue.py tests/test_github_source_commit_digest.py tests/test_canva_widget_click_smoke.py tests/test_dev_server_browser_smoke.py tests/test_dev_server_mcp_contract.py tests/test_dev_server_mcp_runtime.py tests/test_dev_server_mcp_runtime_smoke.py -v' for details."
    exit 1
fi

echo "==> Running dashboard UI tests..."
if ! npm.cmd --prefix apps/dashboard test -- --run 2>/dev/null; then
    echo "Dashboard UI test failed. Push blocked."
    echo "   Run 'npm.cmd --prefix apps/dashboard test -- --run' for details."
    exit 1
fi

echo "==> Running dashboard production build..."
if ! npm.cmd --prefix apps/dashboard run build 2>/dev/null; then
    echo "Dashboard production build failed. Push blocked."
    echo "   Run 'npm.cmd --prefix apps/dashboard run build' for details."
    exit 1
fi

echo "==> Running dashboard bundle budget check..."
if ! npm.cmd --prefix apps/dashboard run check:bundle 2>/dev/null; then
    echo "Dashboard bundle budget check failed. Push blocked."
    echo "   Run 'npm.cmd --prefix apps/dashboard run check:bundle' for details."
    exit 1
fi

echo "==> Running Canva MCP typecheck..."
if ! npm.cmd --prefix mcp/canva-mcp run typecheck 2>/dev/null; then
    echo "Canva MCP typecheck failed. Push blocked."
    echo "   Run 'npm.cmd --prefix mcp/canva-mcp run typecheck' for details."
    exit 1
fi

echo "==> Running Canva MCP production build..."
if ! npm.cmd --prefix mcp/canva-mcp run build 2>/dev/null; then
    echo "Canva MCP production build failed. Push blocked."
    echo "   Run 'npm.cmd --prefix mcp/canva-mcp run build' for details."
    exit 1
fi

if ! python ops/scripts/external_credential_handoff.py --check-json docs/reports/2026-06/EXTERNAL_CREDENTIAL_HANDOFF_2026-06-05.json --check-markdown docs/reports/2026-06/EXTERNAL_CREDENTIAL_HANDOFF_2026-06-05.md --check-env-template docs/reports/2026-06/EXTERNAL_CREDENTIAL_HANDOFF_2026-06-05.env.example --check-operator-checklist-json docs/reports/2026-06/EXTERNAL_CREDENTIAL_OPERATOR_CHECKLIST_2026-06-05.json --check-operator-checklist-markdown docs/reports/2026-06/EXTERNAL_CREDENTIAL_OPERATOR_CHECKLIST_2026-06-05.md 2>/dev/null; then
    echo "External credential handoff check failed. Push blocked."
    echo "   Then run 'python ops/scripts/external_credential_handoff.py --check-json docs/reports/2026-06/EXTERNAL_CREDENTIAL_HANDOFF_2026-06-05.json --check-markdown docs/reports/2026-06/EXTERNAL_CREDENTIAL_HANDOFF_2026-06-05.md --check-env-template docs/reports/2026-06/EXTERNAL_CREDENTIAL_HANDOFF_2026-06-05.env.example --check-operator-checklist-json docs/reports/2026-06/EXTERNAL_CREDENTIAL_OPERATOR_CHECKLIST_2026-06-05.json --check-operator-checklist-markdown docs/reports/2026-06/EXTERNAL_CREDENTIAL_OPERATOR_CHECKLIST_2026-06-05.md' for drift details."
    exit 1
fi

if ! python ops/scripts/external_credential_live_verify.py 2>/dev/null; then
    echo "External credential live verifier dry-run failed. Push blocked."
    echo "   Then run 'python ops/scripts/external_credential_live_verify.py' for boundary planning details."
    exit 1
fi

if ! python ops/scripts/telegram_notification_live_verify.py 2>/dev/null; then
    echo "Telegram notification live verifier dry-run failed. Push blocked."
    echo "   Then run 'python ops/scripts/telegram_notification_live_verify.py' for Telegram delivery boundary details."
    exit 1
fi

if ! python ops/scripts/autoresearch_objective_coverage.py 2>/dev/null; then
    echo "AutoResearch objective coverage audit failed. Push blocked."
    echo "   Then run 'python ops/scripts/autoresearch_objective_coverage.py' for prompt-to-artifact coverage details."
    exit 1
fi

if ! python ops/scripts/dev_server_mcp_runtime_smoke.py 2>/dev/null; then
    echo "MCP runtime subprocess smoke failed. Push blocked."
    echo "   Then run 'python ops/scripts/dev_server_mcp_runtime_smoke.py' for the subprocess smoke."
    exit 1
fi

if ! python ops/scripts/mcp_service_runtime_smoke.py 2>/dev/null; then
    echo "MCP service runtime smoke failed. Push blocked."
    echo "   Then run 'python ops/scripts/mcp_service_runtime_smoke.py' for service startup/tool-list details."
    exit 1
fi

if ! python ops/scripts/agent_workflow_gate_runner.py --workflow workspace-quality-dashboard --max-gates 1 2>/dev/null; then
    echo "Agent workflow gate runner dry-run failed. Push blocked."
    echo "   Then run 'python ops/scripts/agent_workflow_gate_runner.py --workflow workspace-quality-dashboard --max-gates 1' for gate planning details."
    exit 1
fi

if ! python ops/scripts/agent_workflow_gate_runner.py --workflow desci-launch-readiness --execute --gate-index 2 2>/dev/null; then
    echo "Agent workflow side-effect safety check failed. Push blocked."
    echo "   Then run 'python ops/scripts/agent_workflow_gate_runner.py --workflow desci-launch-readiness --execute --gate-index 2' for safety details."
    exit 1
fi

if ! python ops/scripts/agent_workflow_gate_runner.py --all-workflows --max-gates 1 2>/dev/null; then
    echo "Agent workflow matrix dry-run failed. Push blocked."
    echo "   Then run 'python ops/scripts/agent_workflow_gate_runner.py --all-workflows --max-gates 1' for matrix planning details."
    exit 1
fi

if ! python ops/scripts/autoresearch_completion_audit.py 2>/dev/null; then
    echo "AutoResearch completion audit failed. Push blocked."
    echo "   Then run 'python ops/scripts/autoresearch_completion_audit.py' for completion evidence details."
    exit 1
fi

echo "Smoke passed. Pushing..."
