      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * increase(agriguard_qr_scans_total{event=\"verification_complete\"}[24h]) / clamp_min(increase(agriguard_qr_scans_total{event=\"scan_start\"}[24h]), 1)",
          "legendFormat": "Verification Rate",
          "refId": "A"
        }
      ],
      "title": "QR Verification Success Rate (24h)",
      "type": "gauge"
