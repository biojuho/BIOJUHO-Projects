    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Verification success rate = verification_complete / scan_start. Target: >80%",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 60 },
