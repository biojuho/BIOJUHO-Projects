{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "title": "🔧 VibeDebt — Tech Debt Monitor",
  "uid": "vibedebt-monitor",
  "description": "워크스페이스 기술 부채 추이 및 프로젝트별 건강 상태",
  "tags": ["debt", "quality", "vibedebt"],
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "refresh": "1h",
  "schemaVersion": 38,
  "version": 1,
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "🏥 워크스페이스 부채 요약",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "워크스페이스 전체 부채 점수 (0=건강, 100=위험). 목표: 30 미만 (B등급 유지)",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 16 },
              { "color": "orange", "value": 31 },
              { "color": "red", "value": 51 }
            ]
          },
          "unit": "short",
          "min": 0,
          "max": 100,
          "displayName": "Debt Score"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 5, "x": 0, "y": 1 },
      "id": 10,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "title": "Workspace Debt Score",
      "type": "gauge",
      "targets": [
        {
          "expr": "vibedebt_workspace_score",
          "legendFormat": "Score",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "예상 부채 해결 시간 (원금) — 고복잡도 함수 + TODO + 타입 미비 합산",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "orange", "value": 100 },
              { "color": "red", "value": 200 }
            ]
          },
          "unit": "h",
          "min": 0,
          "displayName": "Remediation Hours"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 5, "x": 5, "y": 1 },
      "id": 11,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "textMode": "auto"
      },
      "title": "예상 해결 시간 (원금)",
      "type": "stat",
      "targets": [
        {
          "expr": "vibedebt_remediation_hours_total",
          "legendFormat": "Hours",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "전체 TODO/FIXME/HACK 개수 — 이자 비용의 대리 지표",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "orange", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "short",
          "displayName": "TODO Count"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 4, "x": 10, "y": 1 },
      "id": 12,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "orientation": "auto"
      },
      "title": "TODO / FIXME 총계",
      "type": "stat",
      "targets": [
        {
          "expr": "vibedebt_todo_count_total",
          "legendFormat": "TODOs",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "radon 사용 가능 여부 (1=radon, 0=AST fallback). radon 없으면 복잡도 정확도 저하.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "short",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "AST fallback" }, "1": { "text": "radon ✓" } } }
          ]
        },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 5, "x": 14, "y": 1 },
      "id": 13,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "orientation": "auto"
      },
      "title": "분석 엔진",
      "type": "stat",
      "targets": [
        {
          "expr": "vibedebt_radon_available",
          "legendFormat": "Engine",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "스캔된 Python 파일 총 수",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "unit": "short",
          "displayName": "Python Files"
        },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 5, "x": 14, "y": 4 },
      "id": 14,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "orientation": "auto"
