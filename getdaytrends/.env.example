# ===================================================
#  .env 파일 - 본인의 API 키를 여기에 입력하세요
# ===================================================

# [필수] Anthropic Claude API Key
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===================================================
# [선택 1] Notion에 저장할 경우
# ===================================================
# Notion Integration Token
# https://www.notion.so/my-integrations 에서 발급
NOTION_TOKEN=your_notion_integration_token_here

# 저장할 Notion Database ID
# 데이터베이스 URL: https://notion.so/xxxxxxxxxxxxxxxx?v=...
# 위 URL에서 'notion.so/' 뒤, '?' 앞의 32자리가 Database ID
NOTION_DATABASE_ID=your_notion_database_id_here

# ===================================================
# [선택 2] Google Sheets에 저장할 경우
# ===================================================
# Google Service Account JSON 파일 경로
# https://console.cloud.google.com 에서 서비스 계정 생성 후 JSON 다운로드
GOOGLE_SERVICE_ACCOUNT_JSON=credentials.json

# 저장할 Google Sheets ID
# 스프레드시트 URL: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ===================================================
# [설정] 저장 방식 선택: "notion" 또는 "google_sheets"
# ===================================================
STORAGE_TYPE=notion

# ===================================================
# [설정] 스케줄 간격 (분 단위, 기본값: 120분 = 2시간)
# ===================================================
SCHEDULE_INTERVAL_MINUTES=120

# ===================================================
# [설정] 트윗 생성 톤앤매너
# ===================================================
TONE=친근하고 위트 있는 동네 친구
