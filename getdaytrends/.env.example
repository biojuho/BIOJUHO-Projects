# ===================================================
#  getdaytrends v2.0 환경변수
# ===================================================

# [필수] Anthropic Claude API Key
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===================================================
# [선택 1] Notion에 저장할 경우
# ===================================================
NOTION_TOKEN=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here

# ===================================================
# [선택 2] Google Sheets에 저장할 경우
# ===================================================
GOOGLE_SERVICE_ACCOUNT_JSON=credentials.json
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ===================================================
# [설정] 저장 방식: "notion", "google_sheets", "both", "none"
# ===================================================
STORAGE_TYPE=notion

# ===================================================
# [설정] 스케줄 간격 (분 단위, 기본값: 120분 = 2시간)
# ===================================================
SCHEDULE_INTERVAL_MINUTES=120

# ===================================================
# [설정] 트윗 생성 톤앤매너
# ===================================================
TONE=친근하고 위트 있는 동네 친구

# ===================================================
# [v2.0] 멀티소스 수집 - X API v2 (선택)
# https://developer.twitter.com 에서 Bearer Token 발급
# 없으면 X 데이터 없이 동작 (Reddit + News만 사용)
# ===================================================
TWITTER_BEARER_TOKEN=

# ===================================================
# [v2.0] 알림 - Telegram (선택)
# @BotFather에서 봇 생성 후 토큰 발급
# ===================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===================================================
# [v2.0] 알림 - Discord (선택)
# 서버 설정 > 연동 > 웹훅에서 URL 생성
# ===================================================
DISCORD_WEBHOOK_URL=

# ===================================================
# [v2.0] 알림 임계값 (viral_potential >= 이 값이면 알림)
# ===================================================
ALERT_THRESHOLD=70

# ===================================================
# [v2.0] Claude 모델 설정
# 스코어링(저비용): claude-3-haiku-20240307
# 트윗 생성(고품질): claude-sonnet-4-20250514
# ===================================================
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MODEL_SCORING=claude-3-haiku-20240307

# ===================================================
# [v2.0] 기본 국가 / 트렌드 수
# ===================================================
DEFAULT_COUNTRY=korea
DEFAULT_LIMIT=5

# ===================================================
# [v2.0] SQLite DB 경로
# ===================================================
DB_PATH=data/getdaytrends.db
