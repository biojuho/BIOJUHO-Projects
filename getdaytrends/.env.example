# =====================================================
#  getdaytrends v4.0 — 환경변수 예시 (복사하여 .env로 사용)
#  LLM API 키는 상위 루트의 shared.llm 모듈에서 관리
# =====================================================

# ── 저장 방식 ─────────────────────────────────────────
# "notion" | "google_sheets" | "both" | "none"
STORAGE_TYPE=notion

# ── Notion (STORAGE_TYPE=notion 일 때 필수) ──────────
# https://www.notion.so/my-integrations 에서 발급
NOTION_TOKEN=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here

# ── Google Sheets (STORAGE_TYPE=google_sheets 일 때) ─
GOOGLE_SERVICE_ACCOUNT_JSON=credentials.json
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ── 생성 페르소나 ────────────────────────────────────
# "joongyeon"  : 중연 인플루언서 스타일 (킥 포인트, 해시태그 없음)
# "친근하고 위트 있는 동네 친구" : 기본값
TONE=joongyeon
# 장문/Threads/블로그 편집 프로필: report | classic
EDITORIAL_PROFILE=report

# ── 스케줄 & 수집 ────────────────────────────────────
SCHEDULE_INTERVAL_MINUTES=240   # 파이프라인 실행 간격 (분)
DEFAULT_LIMIT=10                 # 처리할 트렌드 수
DEFAULT_COUNTRY=korea            # 기본 국가 (korea/us/japan 등)
DEDUPE_WINDOW_HOURS=24           # 동일 트렌드 중복 제거 윈도우 (시간)

# ── 바이럴 스코어링 필터 ──────────────────────────────
MIN_VIRAL_SCORE=60              # 미만이면 콘텐츠 생성 건너뜀
ALERT_THRESHOLD=75              # 이상이면 Telegram/Discord 알림 전송
EXCLUDE_CATEGORIES=정치,연예      # 이 카테고리 트렌드 자동 제외 (쉼표 구분)

# ── 콘텐츠 생성 기준 점수 ─────────────────────────────
LONG_FORM_MIN_SCORE=95          # 이상만 Premium+ 장문 생성 (비용↑)
THREAD_MIN_SCORE=92             # 이상만 X 쓰레드 생성
THREADS_MIN_SCORE=65            # 이상만 Meta Threads 생성

# ── v4.0 트렌드 검증 & 하이브리드 스코어링 ─────────────
# Phase 1: 멀티소스 교차 검증 (0~4점)
# 0=볼륨없음, 1=볼륨, 2=볼륨+X, 3=볼륨+X+뉴스, 4=볼륨+X+뉴스+Reddit
MIN_CROSS_SOURCE_CONFIDENCE=2   # 미만이면 viral_potential ×0.65 패널티

# Phase 2: 하이브리드 스코어링 가중치
# 최종점수 = LLM점수×w + 시그널점수×(1-w)
# 시그널 = 볼륨(30)+가속도(25)+소스교차(25)+신선도(20)
VIRAL_SCORE_LLM_WEIGHT=0.6      # LLM 점수 비중 (0.0~1.0)

# Phase 3: 히스토리 패턴 보정
# rising +15%, new +10%, stable -10%, falling -25%
ENABLE_HISTORY_CORRECTION=true

# Phase 4: 중연 킥 포인트
# joongyeon_kick >= 이 값이면 LONG_FORM_MIN_SCORE 기준 우회
JOONGYEON_KICK_LONG_FORM_THRESHOLD=75

# ── 기능 플래그 ───────────────────────────────────────
ENABLE_CLUSTERING=true          # 유사 트렌드 클러스터링 (중복 그룹핑)
ENABLE_LONG_FORM=true           # Premium+ 장문 콘텐츠 생성
ENABLE_THREADS=true             # X 쓰레드 생성
SMART_SCHEDULE=true             # 최적 포스팅 타이밍 자동 조절
NIGHT_MODE=true                 # 야간(02~07시) 실행 빈도 축소
ENABLE_SENTIMENT_FILTER=true    # 유해 트렌드 자동 필터 (safety_flag)
ENABLE_AB_VARIANTS=false        # A/B 변형 생성 (추가 LLM 비용↑)
ENABLE_MULTILANG=false          # 멀티언어 생성 (추가 LLM 비용↑)

# ── 성능 & DB ─────────────────────────────────────────
MAX_WORKERS=10                  # 동시 HTTP 요청 수
CACHE_VOLUME_BUCKET=5000        # 핑거프린트 볼륨 버킷 크기 (작을수록 정밀)
DATA_RETENTION_DAYS=90          # DB 보존 기간 (일)
NOTION_SEM_LIMIT=10             # Notion 동시 저장 세마포어
DB_PATH=data/getdaytrends.db    # SQLite DB 경로

# ── 일일 예산 제어 ────────────────────────────────────
DAILY_BUDGET_USD=2.0            # 일 예산 상한 ($). 초과 시 Sonnet 자동 비활성화
PEAK_BUDGET_MULTIPLIER=0.5      # 야간(22~07시) 예산 = daily × 이 값
COST_ALERT_PCT=70.0             # 예산의 이 % 도달 시 경고 알림

# ── 알림 채널 (선택) ──────────────────────────────────
# @BotFather에서 봇 생성 후 토큰 발급
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Discord 서버 설정 > 연동 > 웹훅에서 URL 생성
DISCORD_WEBHOOK_URL=

# ── X API (선택) ─────────────────────────────────────
# 없으면 Jina 스크래핑으로 자동 폴백 (컨텍스트 수집 가능)
# https://developer.twitter.com 에서 Bearer Token 발급
TWITTER_BEARER_TOKEN=

# ── LLM API 키 ────────────────────────────────────────
# shared.llm 모듈이 아래 키 순서로 자동 폴백:
# deepseek → gemini → grok → openai → anthropic → moonshot
# 루트 .env에서 관리하는 것을 권장 (프로젝트 간 공유)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
XAI_API_KEY=your_xai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
MOONSHOT_API_KEY=your_moonshot_api_key_here
ZHIPUAI_API_KEY=your_zhipuai_api_key_here

# ── 기타 서비스 ───────────────────────────────────────
IMGBB_API_KEY=your_imgbb_api_key_here   # 이미지 업로드 (dashboard용)

# ── PostgreSQL (선택 — 기본값: SQLite) ───────────────
# DATABASE_URL=postgresql://user:pw@host:5432/getdaytrends

# ── Canva 이미지 자동생성 (미구현, 예약) ──────────────
# CANVA_API_KEY=
# CANVA_CLIENT_ID=
# CANVA_CLIENT_SECRET=
# CANVA_TEMPLATE_ID=

# ═══════════════════════════════════════════════════
#  v9.0 Phase A: 비용 최적화
# ═══════════════════════════════════════════════════
# 클러스터링: false=로컬 Jaccard(LLM 호출 없음), true=LLM 클러스터링
ENABLE_LLM_CLUSTERING=false
JACCARD_CLUSTER_THRESHOLD=0.35     # 유사도 임계값 (낮을수록 더 많이 묶음)

# QA Audit 조건부 스킵
QA_SKIP_CACHED=true                # 캐시 재사용 콘텐츠 QA 스킵
QA_SKIP_HIGH_SCORE=85              # 이 점수 이상 트렌드 QA 스킵
QA_SKIP_CATEGORIES=날씨,음식,스포츠  # 저위험 카테고리 QA 스킵
QUALITY_FEEDBACK_MIN_SCORE=50      # short 트윗 QA 최소 점수
THREADS_QUALITY_MIN_SCORE=65       # Threads QA 최소 점수
LONG_FORM_QUALITY_MIN_SCORE=70     # X 장문 QA 최소 점수
BLOG_QUALITY_MIN_SCORE=75          # 블로그 QA 최소 점수

# 시간대별 생성 모드
# "": auto(피크=full, 비피크=lite) | "full": 항상 장문 포함 | "lite": 항상 단문만
GENERATION_MODE=

# ═══════════════════════════════════════════════════
#  v9.0 Phase B: 품질 최적화
# ═══════════════════════════════════════════════════
# Watchlist: 등장 시 즉시 알림 받을 키워드 (쉼표 구분)
# 예: WATCHLIST_KEYWORDS=OpenAI,Claude,삼성전자,GPT
WATCHLIST_KEYWORDS=

# 콘텐츠 다양성: 이전 생성 트윗을 프롬프트에 주입해 중복 표현 방지
ENABLE_CONTENT_DIVERSITY=true
CONTENT_DIVERSITY_HOURS=24         # 이전 트윗 조회 범위 (시간)

# 벨로시티 지표: 런 간 볼륨 상승 속도를 신호 점수에 반영
ENABLE_VELOCITY_SCORING=true
