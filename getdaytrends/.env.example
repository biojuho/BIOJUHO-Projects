# ===================================================
#  getdaytrends v2.0 환경변수
# ===================================================

# [필수] Anthropic Claude API Key
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===================================================
# [선택 1] Notion에 저장할 경우
# ===================================================
NOTION_TOKEN=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here

# ===================================================
# [선택 2] Google Sheets에 저장할 경우
# ===================================================
GOOGLE_SERVICE_ACCOUNT_JSON=credentials.json
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ===================================================
# [설정] 저장 방식: "notion", "google_sheets", "both", "none"
# ===================================================
STORAGE_TYPE=notion

# ===================================================
# [설정] 스케줄 간격 (분 단위, 기본값: 120분 = 2시간)
# ===================================================
SCHEDULE_INTERVAL_MINUTES=120

# ===================================================
# [설정] 트윗 생성 톤앤매너
# ===================================================
TONE=친근하고 위트 있는 동네 친구

# ===================================================
# [v2.0] 멀티소스 수집 - X API v2 (선택)
# https://developer.twitter.com 에서 Bearer Token 발급
# 없으면 X 데이터 없이 동작 (Reddit + News만 사용)
# ===================================================
TWITTER_BEARER_TOKEN=

# ===================================================
# [v2.0] 알림 - Telegram (선택)
# @BotFather에서 봇 생성 후 토큰 발급
# ===================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===================================================
# [v2.0] 알림 - Discord (선택)
# 서버 설정 > 연동 > 웹훅에서 URL 생성
# ===================================================
DISCORD_WEBHOOK_URL=

# ===================================================
# [v2.0] 알림 임계값 (viral_potential >= 이 값이면 알림)
# ===================================================
ALERT_THRESHOLD=70

# ===================================================
# [v2.0] Claude 모델 설정
# 스코어링(저비용): claude-3-haiku-20240307
# 트윗 생성(고품질): claude-sonnet-4-20250514
# ===================================================
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MODEL_SCORING=claude-3-haiku-20240307

# ===================================================
# [v2.0] 기본 국가 / 트렌드 수
# ===================================================
DEFAULT_COUNTRY=korea
DEFAULT_LIMIT=5

# ===================================================
# [v2.0] SQLite DB 경로
# ===================================================
DB_PATH=data/getdaytrends.db

# ===================================================
# [v2.1] 기능 플래그 - Feature Flags
# ===================================================

# 유사 트렌드 클러스터링 (중복 트렌드를 그룹핑)
# true: 유사 키워드를 묶어 대표 트렌드만 트윗 생성
ENABLE_CLUSTERING=true

# 장문 콘텐츠 생성 (높은 스코어 트렌드에 대해 심층 분석글 작성)
ENABLE_LONG_FORM=true

# 트위터 스레드 생성 (단일 트윗 대신 연결된 스레드 형태)
ENABLE_THREADS=true

# 스마트 스케줄링 (시간대별 최적 게시 타이밍 자동 조절)
SMART_SCHEDULE=true

# 야간 모드 (심야 시간대 게시 빈도 자동 축소)
NIGHT_MODE=true

# ===================================================
# [v2.1] 수치 설정
# ===================================================

# 장문 콘텐츠 생성 최소 스코어 (viral_potential >= 이 값이면 장문 생성)
LONG_FORM_MIN_SCORE=70

# 병렬 처리 워커 수 (트렌드 분석 동시 처리 스레드)
MAX_WORKERS=6

# 중복 제거 윈도우 (시간 단위, 이 시간 내 동일 트렌드는 건너뜀)
DEDUPE_WINDOW_HOURS=3
