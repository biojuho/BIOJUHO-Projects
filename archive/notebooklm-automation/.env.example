# NotebookLM Automation — Environment Variables
# Copy to .env and fill in your values

# --- API Server ---
NOTEBOOKLM_API_HOST=0.0.0.0
NOTEBOOKLM_API_PORT=8788

# --- Auth ---
NOTEBOOKLM_HOME=~/.notebooklm
NOTEBOOKLM_REFRESH_THRESHOLD_H=20

# --- Content Defaults ---
NOTEBOOKLM_CONTENT_TYPES=audio
NOTEBOOKLM_AUDIO_INSTRUCTIONS=한국어로 핵심 내용을 2분 브리핑으로 요약해줘
NOTEBOOKLM_MIN_VIRAL=75
NOTEBOOKLM_OUTPUT_DIR=./notebooklm_output

# --- Notion ---
NOTION_API_KEY=
NOTION_DATABASE_ID=

# --- X/Twitter ---
X_ACCESS_TOKEN=

# --- Alerts (Phase 3) ---
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Email Alerts (optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL=

# --- Google Drive (n8n workflow) ---
GDRIVE_NOTEBOOKLM_FOLDER_ID=
