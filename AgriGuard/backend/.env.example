# AgriGuard Backend Configuration
# Default local PostgreSQL target used by Alembic and the API.
DATABASE_URL=postgresql://agriguard:change_me@localhost:5432/agriguard
AUTO_CREATE_SCHEMA=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
SECRET_KEY=change_me
GOOGLE_APPLICATION_CREDENTIALS=firebase-service-account.json
ALLOW_TEST_BYPASS=true

# Optional SQLite fallback for quick local demos only.
# DATABASE_URL=sqlite:///./agriguard.db
# AUTO_CREATE_SCHEMA=true
