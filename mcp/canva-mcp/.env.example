# Canva MCP Server Configuration

# Canva OAuth Credentials (Required for all Canva tools)
# Get these from: https://www.canva.com/developers/apps
CANVA_CLIENT_ID=your_canva_client_id
CANVA_CLIENT_SECRET=your_canva_client_secret
CANVA_REDIRECT_URI=http://127.0.0.1:8001/auth/callback

# Server Configuration
PORT=8001

# Token Storage: 'memory' (default) or 'file'
# - memory: tokens live in process memory, lost on restart (good for development)
# - file:   tokens persist to data/tokens.json (good for simple production without Redis)
TOKEN_STORE=memory

# Rate Limiting
# Maximum API requests per session per minute (default: 60)
RATE_LIMIT_PER_MINUTE=60

# Required OAuth Scopes (configured in your Canva app):
# - asset:read - Read access to user's assets
# - asset:write - Upload and manage assets
# - comment:read - Read comments on designs
# - comment:write - Create and reply to comments
# - design:content:read - Read design content
# - design:content:write - Edit design content
# - design:meta:read - Read design metadata
# - folder:read - Read folder structure
# - folder:write - Create and manage folders
# - profile:read - Read user profile information
