{
  "name": "canva-mcp-server",
  "version": "1.0.0",
  "description": "Model Context Protocol server for Canva integration with ChatGPT Apps SDK",
  "type": "module",
  "main": "dist/server/server.js",
  "scripts": {
    "dev": "tsx src/server/server.ts",
    "dev:preview": "vite --configLoader native",
    "build": "tsc && vite build --configLoader native",
    "build:server": "tsc -p tsconfig.build.json",
    "build:widgets": "vite build --configLoader native",
    "start": "node dist/server/server.js",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview --configLoader native"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "canva",
    "chatgpt",
    "openai",
    "apps-sdk",
    "design",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "dotenv": "^17.4.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "wrangler": "^4.90.1"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
