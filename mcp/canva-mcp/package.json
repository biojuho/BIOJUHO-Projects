{
  "name": "canva-mcp-server",
  "version": "1.0.0",
  "description": "Model Context Protocol server for Canva integration with ChatGPT Apps SDK",
  "type": "module",
  "main": "dist/server/server.js",
  "scripts": {
    "dev": "tsx src/server/server.ts",
    "dev:preview": "vite",
    "build": "tsc && vite build",
    "build:server": "tsc -p tsconfig.build.json",
    "build:widgets": "vite build",
    "start": "node dist/server/server.js",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "canva",
    "chatgpt",
    "openai",
    "apps-sdk",
    "design",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "dotenv": "^17.3.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251120.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vite": "^8.0.3",
    "wrangler": "^4.50.0"
  },
  "engines": {
    "node": ">=20.19 <24"
  }
}
