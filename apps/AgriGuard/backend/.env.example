# AgriGuard Backend Configuration
# Default local PostgreSQL target used by Alembic and the API.
DATABASE_URL=postgresql://agriguard:change_me@localhost:5432/agriguard
AUTO_CREATE_SCHEMA=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
SECRET_KEY=change_me
# Required for /admin login. Leave blank until a strong local secret is set.
ADMIN_PASSWORD=
GOOGLE_APPLICATION_CREDENTIALS=firebase-service-account.json
# Test bypass accepts only the literal test token and should stay off outside tests.
ALLOW_TEST_BYPASS=false
# Local-only fallback when Firebase Admin is unavailable.
# ALLOW_DEV_AUTH_FALLBACK=true
REDIS_URL=redis://localhost:6379/0
# Enable only on a designated dev or ingest worker.
# IOT_SIMULATION_ENABLED=true
# MQTT_BROKER_HOST=localhost
# MQTT_BROKER_PORT=1883
# IOT_MQTT_ENABLED=true
# IOT_INGEST_LOCK_PATH=.iot-ingest.lock

# Optional SQLite fallback for quick local demos only.
# DATABASE_URL=sqlite:///./agriguard.db
# AUTO_CREATE_SCHEMA=true
