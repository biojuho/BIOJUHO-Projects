# AgriGuard Backend
AGRIGUARD_DB_USER=agriguard
AGRIGUARD_DB_PASSWORD=change_me
AGRIGUARD_DB_NAME=agriguard
DATABASE_URL=postgresql://agriguard:change_me@localhost:5432/agriguard
AUTO_CREATE_SCHEMA=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
SECRET_KEY=change_me
GOOGLE_APPLICATION_CREDENTIALS=backend/firebase-service-account.json
ALLOW_TEST_BYPASS=true
REDIS_URL=redis://localhost:6379/0
# Enable only on a designated dev or ingest worker.
# IOT_SIMULATION_ENABLED=true
# MQTT_BROKER_HOST=localhost
# MQTT_BROKER_PORT=1883
# IOT_MQTT_ENABLED=true
# IOT_INGEST_LOCK_PATH=backend/.iot-ingest.lock

# Optional SQLite fallback for quick local demos only.
# DATABASE_URL=sqlite:///./backend/agriguard.db
# AUTO_CREATE_SCHEMA=true

# AgriGuard Contracts (Sepolia Testnet)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
PRIVATE_KEY=your_wallet_private_key_here
ETHERSCAN_API_KEY=your_etherscan_api_key
