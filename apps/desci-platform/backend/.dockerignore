# Python cruft
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Secrets / local env — never bake into the image
.env
.env.*
!.env.example
serviceAccountKey.json
*.pem
*.key

# Runtime / generated data (use a volume instead of baking into the image)
chroma_db/
var/
*.db
*.sqlite
*.sqlite3
*.log

# Tests & docs are not needed at runtime
tests/
test_*.py
*_test.py

# VCS / editors / OS
.git/
.gitignore
.vscode/
.idea/
.DS_Store
*.md
