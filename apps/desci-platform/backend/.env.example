# BioLinker Environment Variables
# Copy this file to .env and configure

# OpenAI (LLM 분석 활성화)
OPENAI_API_KEY=your_openai_api_key_here

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175

# Development auth fallback, local only.
# ALLOW_DEV_AUTH_FALLBACK=true

# Pinata IPFS (선택)
PINATA_JWT=your_pinata_jwt_here
# OR
PINATA_API_KEY=your_pinata_api_key
PINATA_API_SECRET=your_pinata_secret

# Web3 / Ethereum (선택)
WEB3_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
DSCI_CONTRACT_ADDRESS=0x...your_contract_address
NFT_CONTRACT_ADDRESS=0x...your_nft_contract_address
# Optional future governance contract wiring
DESCI_DAO_CONTRACT_ADDRESS=0x...your_dao_contract_address
DISTRIBUTOR_PRIVATE_KEY=your_private_key_for_rewards


GOOGLE_API_KEY=your_google_api_key_here
