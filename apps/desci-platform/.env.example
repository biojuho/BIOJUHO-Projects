# ============== LLM API Keys ==============
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ENABLE_DEEPSEEK_KO_LONGFORM=false

# ============== Firebase Config (Frontend) ==============
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_bucket.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ============== Firebase Config (Backend) ==============
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# ============== PostgreSQL / Supabase ==============
DATABASE_URL=postgresql://desci:desci@localhost:5432/desci
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============== Cache / Queue ==============
REDIS_URL=redis://localhost:6379/0
RABBITMQ_URL=amqp://desci:desci@localhost:5672/desci
RABBITMQ_JOB_QUEUE=biolinker.jobs

# ============== Backend URL ==============
VITE_API_BASE_URL=http://127.0.0.1:8000

# ============== Scientific PDF Parsing (GROBID) ==============
GROBID_ENABLED=true
GROBID_URL=http://grobid:8070/api
GROBID_TIMEOUT_SECONDS=60

# ============== Vector Store Backend ==============
VECTOR_STORE_BACKEND=chroma
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=rfp_notices
QDRANT_TIMEOUT_SECONDS=10

# ============== IPFS (Pinata) ==============
PINATA_API_KEY=your_pinata_api_key
PINATA_API_SECRET=your_pinata_api_secret

# ============== Web3 / Blockchain ==============
PRIVATE_KEY=your_wallet_private_key
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# ============== CORS ==============
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ============== Development ==============
# ALLOW_TEST_BYPASS=true
# ALLOW_DEV_AUTH_FALLBACK=true
