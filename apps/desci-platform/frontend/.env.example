# Frontend Environment Variables
# Copy this file to .env and fill in your Firebase config.
# Public local smoke routes fall back to inert auth when these values are absent
# or left as placeholders. Real login/signup still require a valid Firebase app.

VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional direct Supabase reads; writes should go through the backend first.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
