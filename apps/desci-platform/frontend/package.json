    "firebase": "^12.13.0",
    "framer-motion": "^12.39.0",
    "html2pdf.js": "^0.14.0",
    "lucide-react": "^1.16.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-error-boundary": "^6.1.1",
    "react-markdown": "^10.1.0",
