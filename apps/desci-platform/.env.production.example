# DSCI-DecentBio production environment template.
# Replace every placeholder before running:
#   python scripts/env_doctor.py --profile production --env-file .env.production --ignore-process-env

ENV=production
LOG_LEVEL=INFO

# LLM provider, at least one required.
GEMINI_API_KEY=your_gemini_api_key
GOOGLE_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# Frontend deployment.
VITE_API_BASE_URL=https://api.example.com
ALLOWED_ORIGINS=https://app.example.com

# Frontend Firebase.
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Backend Firebase/Auth. Prefer secret manager injection in production.
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON=

# PostgreSQL / Supabase.
DATABASE_URL=postgresql://user:password@host:5432/desci
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Cache / Queue.
REDIS_URL=rediss://user:password@host:6379/0
RABBITMQ_URL=amqps://user:password@host:5671/desci
RABBITMQ_JOB_QUEUE=biolinker.jobs

# Scientific PDF parsing.
GROBID_ENABLED=true
GROBID_URL=https://grobid.example.com/api
GROBID_TIMEOUT_SECONDS=60

# Vector store.
VECTOR_STORE_BACKEND=qdrant
QDRANT_URL=https://qdrant.example.com
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION_NAME=rfp_notices
QDRANT_TIMEOUT_SECONDS=10

# IPFS / Pinata.
PINATA_JWT=your_pinata_jwt

# Web3 / Blockchain.
WEB3_RPC_URL=https://polygon-amoy.infura.io/v3/your_key
DSCI_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
NFT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
# Optional governance contract for future on-chain proposal reads.
DESCI_DAO_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
DISTRIBUTOR_PRIVATE_KEY=use_secret_manager_not_plaintext

# Billing.
STRIPE_SECRET_KEY=sk_live_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
STRIPE_PRICE_PRO_MONTHLY=price_live_pro_monthly
STRIPE_PRICE_PRO_YEARLY=price_live_pro_yearly
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_live_enterprise_monthly
STRIPE_PRICE_ENTERPRISE_YEARLY=price_live_enterprise_yearly
DESCI_FRONTEND_URL=https://app.example.com
